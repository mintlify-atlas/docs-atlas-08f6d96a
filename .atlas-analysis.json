  "keyFeatures": [
    "Unified API interface for Grok, Cerebras, Gemini, and OpenRouter LLM providers",
    "Round Robin load balancing with automatic provider selection",
    "Adaptive Circuit Breaker with closed/degraded/open/half-open states",
    "Dual API versioning: v1 (OpenAI-style messages) and v2 (advanced prompt options)",
    "Real-time streaming responses via Server-Sent Events",
    "Batch processing for multiple concurrent requests",
    "API key management with SHA-256 hashing and admin ownership controls",
    "Per-client rate limiting with configurable limits",
    "Prometheus metrics integration for observability",
    "Security headers, CORS configuration, and HTTPS redirect support"
  ],
  "publicApiSurface": [
    "POST /v1/chat",
    "POST /v1/chat/no-stream",
    "POST /v2/chat",
    "POST /v2/chat/no-stream",
    "POST /v1/batch/chat",
    "GET /v1/health",
    "GET /v2/health",
    "GET /v1/providers",
    "GET /v2/providers",
    "GET /v1/metrics",
    "GET /v1/circuit-breaker",
    "GET /v2/circuit-breaker",
    "POST /v1/circuit-breaker/{provider}/reset",
    "POST /v2/circuit-breaker/{provider}/reset",
    "POST /admin/keys",
    "GET /admin/keys",
    "DELETE /admin/keys/{name}"
  ]
